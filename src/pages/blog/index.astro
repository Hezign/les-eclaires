---
import Base from '../../layouts/Base.astro';

const posts = await Astro.glob('./*.md');
const sorted = posts.sort((a, b) => 
  new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime()
);
---
<Base title="Blog IRVE — Les Éclairés" description="Guides pratiques, décryptages réglementaires et conseils d'installation de bornes de recharge. Sans jargon.">

<style>
  :root {
    --c-bg:#F8F6F1; --c-bg2:#FFFFFF; --c-bg3:#F0EDE6;
    --c-border:rgba(0,0,0,0.07); --c-border2:rgba(0,0,0,0.13);
    --c-ink:#111110; --c-muted:#888884; --c-mid:#55554F; --c-text:#2C2C28;
    --c-vert:#00A96E; --c-vert-lt:#00C97F;
    --c-vert-bg:rgba(0,169,110,.08); --c-vert-br:rgba(0,169,110,.22);
    --ff-h:'Bricolage Grotesque',sans-serif; --ff-b:'Inter',sans-serif;
    --ease-out:cubic-bezier(0.16,1,0.3,1);
    --r-xl:24px; --r-full:999px;
    --shadow-card:0 1px 3px rgba(0,0,0,.06),0 4px 16px rgba(0,0,0,.06);
    --shadow-hover:0 8px 32px rgba(0,0,0,.10),0 2px 8px rgba(0,0,0,.06);
  }
  *,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
  html{-webkit-font-smoothing:antialiased}
  body{background:var(--c-bg);color:var(--c-text);font-family:var(--ff-b);font-size:16px;line-height:1.6}
  h1,h2,h3{font-family:var(--ff-h);color:var(--c-ink);letter-spacing:-0.04em}
  a{color:inherit;text-decoration:none}

  nav{position:fixed;top:16px;left:50%;transform:translateX(-50%);z-index:200;height:56px;width:calc(100% - 48px);max-width:1100px;display:flex;align-items:center;justify-content:space-between;padding:0 28px;background:rgba(248,246,241,0.96);backdrop-filter:blur(24px) saturate(1.4);border:1px solid var(--c-border2);border-radius:100px;box-shadow:0 4px 24px rgba(0,0,0,.07)}
  .nav-logo{display:flex;align-items:center;gap:10px}
  .nav-logo img{height:28px;width:auto;object-fit:contain}
  .nav-logo span{font-family:var(--ff-h);font-size:16px;font-weight:700;color:var(--c-ink);letter-spacing:-0.03em}
  .nav-back{font-family:var(--ff-h);font-size:13.5px;font-weight:500;color:var(--c-muted);display:flex;align-items:center;gap:6px;transition:color .18s}
  .nav-back:hover{color:var(--c-ink)}

  .page{max-width:1080px;margin:0 auto;padding:120px 48px 80px}
  .page-header{margin-bottom:56px}
  .eyebrow{display:inline-flex;align-items:center;gap:8px;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.12em;color:var(--c-vert);margin-bottom:16px}
  .eyebrow::before{content:'';display:inline-block;width:14px;height:1px;background:var(--c-vert)}
  h1{font-size:clamp(36px,5vw,60px);font-weight:800;margin-bottom:16px}
  .lead{font-size:17px;font-weight:300;color:var(--c-mid);line-height:1.8;max-width:520px}

  .posts-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
  .post-card{background:var(--c-bg2);border:1px solid var(--c-border);border-radius:var(--r-xl);overflow:hidden;box-shadow:var(--shadow-card);transition:transform .25s var(--ease-out),box-shadow .25s;display:flex;flex-direction:column}
  .post-card:hover{transform:translateY(-4px);box-shadow:var(--shadow-hover)}
  .post-thumb{height:160px;display:flex;align-items:center;justify-content:center;font-size:48px;position:relative}
  .post-tag{position:absolute;top:14px;left:14px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;padding:3px 10px;border-radius:var(--r-full);background:rgba(0,0,0,.07);color:var(--c-mid)}
  .post-body{padding:24px;display:flex;flex-direction:column;flex:1}
  .post-date{font-size:11px;color:var(--c-muted);margin-bottom:8px}
  .post-title{font-family:var(--ff-h);font-size:17px;font-weight:700;letter-spacing:-0.035em;color:var(--c-ink);line-height:1.3;margin-bottom:10px}
  .post-excerpt{font-size:13px;color:var(--c-muted);line-height:1.65;font-weight:300;flex:1;margin-bottom:16px}
  .post-cta{font-family:var(--ff-h);font-size:12px;font-weight:600;color:var(--c-vert);display:inline-flex;align-items:center;gap:5px}
  .post-card:hover .post-cta{gap:8px}

  .empty{text-align:center;padding:80px 20px;color:var(--c-muted)}

  @media(max-width:900px){.posts-grid{grid-template-columns:1fr 1fr}}
  @media(max-width:640px){nav{width:calc(100% - 24px);top:10px;padding:0 20px}.page{padding:100px 20px 60px}.posts-grid{grid-template-columns:1fr}}
</style>

<nav>
  <a class="nav-logo" href="/">
    <img src="/images/logo-le.png" alt="Les Éclairés" />
    <span>Les Éclairés</span>
  </a>
  <a class="nav-back" href="/">
    ← Retour
  </a>
</nav>

<div class="page">
  <div class="page-header">
    <div class="eyebrow">Le blog</div>
    <h1>Tout comprendre sur l'IRVE</h1>
    <p class="lead">Guides pratiques, décryptages réglementaires et conseils d'installation. Sans jargon, sans conflit d'intérêts.</p>
  </div>

  {sorted.length === 0 ? (
    <div class="empty">Les articles arrivent bientôt.</div>
  ) : (
    <div class="posts-grid">
      {sorted.map(post => (
        <a href={post.url} class="post-card">
          <div class="post-thumb" style={`background:${post.frontmatter.thumbBg || 'linear-gradient(135deg,#d4f0e4,#e8f8f0)'}`}>
            <span>{post.frontmatter.emoji || '⚡'}</span>
            <span class="post-tag">{post.frontmatter.tag || 'Guide'}</span>
          </div>
          <div class="post-body">
            <div class="post-date">{post.frontmatter.dateLabel}</div>
            <div class="post-title">{post.frontmatter.title}</div>
            <div class="post-excerpt">{post.frontmatter.excerpt}</div>
            <span class="post-cta">Lire l'article →</span>
          </div>
        </a>
      ))}
    </div>
  )}
</div>

</Base>
