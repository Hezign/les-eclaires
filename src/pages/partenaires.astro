---
import Base from '../layouts/Base.astro';
---
<Base title="Devenir partenaire — Les Éclairés" description="Rejoignez le réseau Les Éclairés. Leads IRVE qualifiés pour installateurs certifiés.">
<style>
:root{
  --c-bg:#F8F6F1; --c-bg2:#FFFFFF; --c-bg3:#F0EDE6;
  --c-border:rgba(0,0,0,0.07); --c-border2:rgba(0,0,0,0.13);
  --c-ink:#111110; --c-muted:#888884; --c-mid:#55554F; --c-text:#2C2C28;
  --c-vert:#00A96E; --c-vert-lt:#00C97F;
  --c-vert-bg:rgba(0,169,110,.08); --c-vert-br:rgba(0,169,110,.22);
  --c-jaune-lt:#FFD60A;
  --ff-h:'Bricolage Grotesque',sans-serif; --ff-b:'Inter',sans-serif;
  --ease-out:cubic-bezier(0.16,1,0.3,1);
  --ease-spring:cubic-bezier(0.34,1.56,0.64,1);
  --r-sm:8px; --r-md:12px; --r-lg:18px; --r-xl:24px; --r-full:999px;
  --shadow-card:0 1px 3px rgba(0,0,0,.06),0 4px 16px rgba(0,0,0,.06);
}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth;-webkit-font-smoothing:antialiased}
body{background:var(--c-bg);color:var(--c-text);font-family:var(--ff-b);font-size:16px;line-height:1.6;overflow-x:hidden}
h1,h2,h3,h4{font-family:var(--ff-h);color:var(--c-ink);letter-spacing:-0.04em;line-height:1.05}
a{color:inherit;text-decoration:none}

/* NAV */
nav{position:fixed;top:16px;left:50%;transform:translateX(-50%);z-index:200;height:56px;width:calc(100% - 48px);max-width:1100px;display:flex;align-items:center;justify-content:space-between;padding:0 28px;background:rgba(248,246,241,0.96);backdrop-filter:blur(24px) saturate(1.4);border:1px solid var(--c-border2);border-radius:100px;box-shadow:0 4px 24px rgba(0,0,0,.07)}
.nav-logo{display:flex;align-items:center;gap:10px}
.nav-logo img{height:28px;width:auto;object-fit:contain}
.nav-logo span{font-family:var(--ff-h);font-size:16px;font-weight:700;color:var(--c-ink);letter-spacing:-0.03em;white-space:nowrap}
.nav-back{font-family:var(--ff-h);font-size:13.5px;font-weight:500;color:var(--c-muted);display:flex;align-items:center;gap:6px;transition:color .18s}
.nav-back:hover{color:var(--c-ink)}
.nav-back svg{width:16px;height:16px}

/* PAGE */
.page-wrap{max-width:1080px;margin:0 auto;padding:128px 48px 80px;display:grid;grid-template-columns:1fr 480px;gap:80px;align-items:start}

/* LEFT */
.page-left{}
.eyebrow{display:inline-flex;align-items:center;gap:8px;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.12em;color:var(--c-vert);margin-bottom:20px}
.eyebrow::before{content:'';display:inline-block;width:14px;height:1px;background:var(--c-vert)}
.page-left h1{font-size:clamp(36px,4vw,56px);font-weight:800;margin-bottom:20px;line-height:1.05}
.page-left .lead{font-size:17px;font-weight:300;color:var(--c-mid);line-height:1.8;margin-bottom:40px;max-width:440px}

.feats{display:flex;flex-direction:column;gap:16px;margin-bottom:48px}
.feat{display:flex;align-items:flex-start;gap:16px;padding:20px;background:var(--c-bg2);border:1px solid var(--c-border);border-radius:var(--r-lg);box-shadow:var(--shadow-card)}
.feat-icon{width:40px;height:40px;border-radius:10px;background:var(--c-vert-bg);border:1px solid var(--c-vert-br);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.feat-icon svg{width:18px;height:18px}
.feat-title{font-family:var(--ff-h);font-size:15px;font-weight:700;letter-spacing:-0.03em;margin-bottom:3px}
.feat-desc{font-size:13px;color:var(--c-muted);font-weight:300;line-height:1.6}

.trust{display:flex;gap:24px;flex-wrap:wrap}
.trust-item{display:flex;align-items:center;gap:8px;font-size:13px;color:var(--c-muted)}
.trust-dot{width:5px;height:5px;border-radius:50%;background:var(--c-vert);flex-shrink:0}

/* RIGHT — FORM CARD */
.form-card{background:var(--c-bg2);border:1px solid var(--c-border);border-radius:var(--r-xl);padding:40px;box-shadow:var(--shadow-card);position:sticky;top:88px}
.form-card h2{font-size:22px;font-weight:800;margin-bottom:6px;letter-spacing:-0.04em}
.form-card .form-sub{font-size:14px;color:var(--c-muted);font-weight:300;margin-bottom:28px}

.field{margin-bottom:16px}
.field label{display:block;font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:.08em;color:var(--c-muted);margin-bottom:6px}
.field input,.field select,.field textarea{
  width:100%;background:var(--c-bg);border:1px solid var(--c-border2);border-radius:var(--r-sm);
  padding:12px 15px;font-size:14px;font-family:var(--ff-b);color:var(--c-text);outline:none;
  transition:border-color .2s,box-shadow .2s;
}
.field input::placeholder,.field textarea::placeholder{color:rgba(0,0,0,.28)}
.field input:focus,.field select:focus,.field textarea:focus{
  border-color:rgba(0,169,110,.5);box-shadow:0 0 0 3px rgba(0,169,110,.1)
}
.field select{appearance:none;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 12 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1l5 5 5-5' stroke='%23888' stroke-width='1.5' stroke-linecap='round'/%3E%3C/svg%3E");background-repeat:no-repeat;background-position:right 14px center;background-size:12px;cursor:pointer}
.field textarea{resize:vertical;min-height:100px;line-height:1.6}
.field-row{display:grid;grid-template-columns:1fr 1fr;gap:12px}

.btn-submit{width:100%;font-family:var(--ff-h);font-size:15px;font-weight:700;background:var(--c-ink);color:#fff;border:none;border-radius:var(--r-full);padding:15px 28px;cursor:pointer;letter-spacing:-0.02em;transition:background .2s,transform .18s var(--ease-spring),box-shadow .2s;margin-top:8px}
.btn-submit:hover{background:#2a2a26;transform:translateY(-2px);box-shadow:0 10px 28px rgba(0,0,0,.2)}
.form-legal{font-size:11px;color:var(--c-muted);text-align:center;margin-top:12px;line-height:1.5}

/* SUCCESS */
.success-wrap{display:none;text-align:center;padding:40px 20px}
.success-wrap.show{display:block}
.success-icon{width:64px;height:64px;background:var(--c-vert-bg);border:1px solid var(--c-vert-br);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 20px}
.success-icon svg{width:28px;height:28px}
.success-wrap h3{font-family:var(--ff-h);font-size:22px;font-weight:800;color:var(--c-vert);margin-bottom:8px}
.success-wrap p{font-size:14px;color:var(--c-muted);line-height:1.7}

@media(max-width:900px){
  .page-wrap{grid-template-columns:1fr;gap:48px;padding:128px 32px 80px}
  .form-card{position:static}
}
@media(max-width:640px){
  nav{width:calc(100% - 24px);top:10px;padding:0 20px}
  .page-wrap{padding:100px 20px 60px}
  .field-row{grid-template-columns:1fr}
}
</style>

<nav>
  <a class="nav-logo" href="index.html">
    <img src="data:image/png;base64," alt="Les Éclairés">
    <span>Les Éclairés</span>
  </a>
  <a class="nav-back" href="index.html">
    <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13L5 8l5-5"/></svg>
    Retour
  </a>
</nav>

<div class="page-wrap">

  <!-- LEFT -->
  <div class="page-left">
    <div class="eyebrow">Installateurs IRVE</div>
    <h1>Rejoignez le réseau des Éclairés</h1>
    <p class="lead">Des leads préqualifiés, contextualisés et prêts à décider. Pas de volume inutile : chaque mise en relation correspond à un projet réel, bien cadré.</p>

    <div class="feats">
      <div class="feat">
        <div class="feat-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="#00A96E" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5M2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
        </div>
        <div>
          <div class="feat-title">Leads qualifiés uniquement</div>
          <div class="feat-desc">Chaque lead a répondu à 6 questions. Vous savez exactement son type de projet, son budget et son urgence avant de le contacter.</div>
        </div>
      </div>
      <div class="feat">
        <div class="feat-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="#00A96E" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
        </div>
        <div>
          <div class="feat-title">Modèle simple et transparent</div>
          <div class="feat-desc">100 € par lead qualifié transmis, plus une commission sur projet signé. Sans abonnement, sans engagement, sans exclusivité territoriale.</div>
        </div>
      </div>
      <div class="feat">
        <div class="feat-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="#00A96E" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><path d="M22 4L12 14.01l-3-3"/></svg>
        </div>
        <div>
          <div class="feat-title">Certification IRVE obligatoire</div>
          <div class="feat-desc">Nous ne référençons que des installateurs certifiés IRVE. Gage de qualité pour nos utilisateurs, différenciation pour vous.</div>
        </div>
      </div>
    </div>

    <div class="trust">
      <span class="trust-item"><span class="trust-dot"></span>Réponse sous 48h ouvrées</span>
      <span class="trust-item"><span class="trust-dot"></span>Partenariat sans engagement</span>
      <span class="trust-item"><span class="trust-dot"></span>Résiliable à tout moment</span>
    </div>
  </div>

  <!-- RIGHT — FORM -->
  <div class="form-card">
    <div id="formWrap">
      <h2>Déposer ma candidature</h2>
      <p class="form-sub">Remplissez ce formulaire, nous vous recontactons sous 48h ouvrées.</p>

      <div class="field-row">
        <div class="field">
          <label>Prénom</label>
          <input type="text" id="fp" placeholder="Jean">
        </div>
        <div class="field">
          <label>Nom</label>
          <input type="text" id="fn" placeholder="Dupont">
        </div>
      </div>
      <div class="field">
        <label>Email professionnel</label>
        <input type="email" id="fe" placeholder="jean@mon-entreprise.fr">
      </div>
      <div class="field">
        <label>Téléphone</label>
        <input type="tel" id="ft" placeholder="+33 6 00 00 00 00">
      </div>
      <div class="field">
        <label>Nom de votre entreprise</label>
        <input type="text" id="fc" placeholder="ElecPro Solutions">
      </div>
      <div class="field">
        <label>Zone d'intervention principale</label>
        <input type="text" id="fz" placeholder="Lyon, Rhône-Alpes">
      </div>
      <div class="field">
        <label>Type de projets traités</label>
        <select id="ft2">
          <option value="">Sélectionner...</option>
          <option>Résidentiel (maisons, copropriétés)</option>
          <option>Professionnel (entreprises, flottes)</option>
          <option>Tertiaire (parkings, collectivités)</option>
          <option>Tous types de projets</option>
        </select>
      </div>
      <div class="field">
        <label>Message (optionnel)</label>
        <textarea id="fm" placeholder="Parlez-nous de votre activité, vos certifications, votre capacité mensuelle..."></textarea>
      </div>

      <button class="btn-submit" id="btnSubmit">Envoyer ma candidature →</button>
      <p class="form-legal">Données confidentielles · Jamais revendues · Conformes RGPD</p>
    </div>

    <div class="success-wrap" id="successWrap">
      <div class="success-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="#00A96E" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
      </div>
      <h3>Candidature reçue !</h3>
      <p>Merci pour votre intérêt. Notre équipe va étudier votre dossier et vous recontacter sous 48h ouvrées pour la suite.</p>
    </div>
  </div>

</div>

<script>
document.getElementById('btnSubmit').addEventListener('click',function(){
  var p=document.getElementById('fp').value.trim();
  var e=document.getElementById('fe').value.trim();
  var c=document.getElementById('fc').value.trim();
  var ok=true;
  [['fp',p],['fe',e],['fc',c]].forEach(function(pair){
    var el=document.getElementById(pair[0]);
    if(!pair[1]){el.style.borderColor='rgba(220,50,50,.5)';ok=false;}
    else{el.style.borderColor='';}
  });
  if(!ok) return;
  document.getElementById('formWrap').style.display='none';
  document.getElementById('successWrap').classList.add('show');
});
</script>

<script>
document.getElementById('btnSubmit').addEventListener('click',function(){
  var p=document.getElementById('fp').value.trim();
  var e=document.getElementById('fe').value.trim();
  var c=document.getElementById('fc').value.trim();
  var ok=true;
  [['fp',p],['fe',e],['fc',c]].forEach(function(pair){
    var el=document.getElementById(pair[0]);
    if(!pair[1]){el.style.borderColor='rgba(220,50,50,.5)';ok=false;}
    else{el.style.borderColor='';}
  });
  if(!ok) return;
  document.getElementById('formWrap').style.display='none';
  document.getElementById('successWrap').classList.add('show');
});
</script>
</Base>
