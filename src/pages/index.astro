<script>
!function(){
/* ── DATA ── */
var D={
  'Maison individuelle':{title:'Profil : Installation résidentielle',sub:'Une borne 7,4 kW wallbox est la solution optimale pour votre usage à domicile.',pow:'7,4 kW',budget:'600 – 1 400 €',aide:'Crédit impôt 75%',delai:'2 à 4 semaines'},
  'Copropriété':{title:'Profil : Droit à la prise',sub:'Vous avez un droit légal à installer votre borne. La procédure est encadrée par la loi ELAN.',pow:'7,4 kW',budget:'1 200 – 2 500 €',aide:'ADVENIR éligible',delai:'6 à 12 semaines'},
  'Entreprise':{title:"Profil : Infrastructure d'entreprise",sub:'Une infrastructure collective avec pilotage intelligent (smart charging) est recommandée.',pow:'22 kW / point',budget:'2 000 – 8 000 €',aide:'TVA récupérable',delai:'4 à 8 semaines'},
  'Parking public':{title:'Profil : Infrastructure publique',sub:"Ce projet nécessite une étude de puissance, une gestion d'itinérance et un appel d'offres.",pow:'22 – 50 kW',budget:'5 000 – 30 000 €',aide:'AMI / FEDER',delai:'3 à 6 mois'}
};
var A={};

/* ── SIMULATOR ── */
function gId(id){return document.getElementById(id);}
window._pick=function pick(el,step,val){
  var all=document.querySelectorAll('#q'+step+' .sim-opt');
  for(var i=0;i<all.length;i++) all[i].classList.remove('sel');
  el.classList.add('sel');
  A[step]=val;
  setTimeout(function(){advance(step);},350);
};
function advance(s){
  var bar=gId('p'+s);
  if(bar){bar.classList.remove('active');bar.classList.add('done');}
  var q=gId('q'+s);
  if(q) q.classList.remove('active');
  if(s<5){
    var nq=gId('q'+(s+1)), nb=gId('p'+(s+1));
    if(nq) nq.classList.add('active');
    if(nb) nb.classList.add('active');
  } else { showResult(); }
}
function showResult(){
  var bars=document.querySelectorAll('#pgBar .sim-pb');
  for(var i=0;i<bars.length;i++){bars[i].classList.remove('active');bars[i].classList.add('done');}
  var r=D[A[0]]||D['Maison individuelle'];
  gId('rTitle').textContent=r.title;
  gId('rSub').textContent=r.sub;
  gId('rPow').textContent=r.pow;
  gId('rBudget').textContent=r.budget;
  gId('rAide').textContent=r.aide;
  gId('rDelai').textContent=r.delai;
  var el=gId('simRes');
  el.classList.add('active');
  setTimeout(function(){el.scrollIntoView({behavior:'smooth',block:'nearest'});},100);
}
window._sf=function submitForm(){
  var p=gId('fP').value.trim(), e=gId('fE').value.trim();
  if(!p){gId('fP').style.borderColor='rgba(220,50,50,.5)';return;}
  if(!e){gId('fE').style.borderColor='rgba(220,50,50,.5)';return;}
  gId('fBox').style.display='none';
  gId('okMsg').classList.add('show');
};

/* ── BIND SIMULATOR CLICKS ── */
function bindSim(){
  document.querySelectorAll('.sim-opt').forEach(function(el){
    var oc=el.getAttribute('onclick');
    if(oc){
      el.removeAttribute('onclick');
      el.addEventListener('click',function(){
