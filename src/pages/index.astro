---
import Base from '../layouts/Base.astro';
---
<Base>
<style>
:root{
  --c-bg:#F8F6F1; --c-bg2:#FFFFFF; --c-bg3:#F0EDE6;
  --c-border:rgba(0,0,0,0.07); --c-border2:rgba(0,0,0,0.13);
  --c-ink:#111110; --c-muted:#888884; --c-mid:#55554F; --c-text:#2C2C28;
  --c-vert:#00A96E; --c-vert-lt:#00C97F;
  --c-vert-bg:rgba(0,169,110,.08); --c-vert-br:rgba(0,169,110,.22);
  --c-jaune:#D4A000; --c-jaune-lt:#FFD60A;
  --c-jaune-bg:rgba(212,160,0,.08); --c-jaune-br:rgba(212,160,0,.22);
  --sp-1:4px;--sp-2:8px;--sp-3:12px;--sp-4:16px;--sp-5:20px;
  --sp-6:24px;--sp-7:28px;--sp-8:32px;--sp-10:40px;--sp-12:48px;
  --sp-16:64px;--sp-20:80px;
  --r-sm:8px;--r-md:12px;--r-lg:18px;--r-xl:24px;--r-full:999px;
  --ff-h:'Bricolage Grotesque',sans-serif;--ff-b:'Inter',sans-serif;
  --ease-out:cubic-bezier(0.16,1,0.3,1);
  --ease-spring:cubic-bezier(0.34,1.56,0.64,1);
  --shadow-card:0 1px 3px rgba(0,0,0,.06),0 4px 16px rgba(0,0,0,.06);
  --shadow-hover:0 8px 32px rgba(0,0,0,.10),0 2px 8px rgba(0,0,0,.06);
}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth;-webkit-font-smoothing:antialiased;text-rendering:optimizeLegibility}
body{background:var(--c-bg);color:var(--c-text);font-family:var(--ff-b);font-size:16px;line-height:1.6;overflow-x:hidden}
h1,h2,h3,h4{font-family:var(--ff-h);color:var(--c-ink);letter-spacing:-0.04em;line-height:1.05}
a{color:inherit;text-decoration:none}

/* ── NAV ── */
nav{position:fixed;top:16px;left:50%;transform:translateX(-50%);z-index:200;height:56px;width:calc(100% - 48px);max-width:1100px;display:flex;align-items:center;justify-content:space-between;padding:0 28px;background:rgba(248,246,241,0.96);backdrop-filter:blur(24px) saturate(1.4);border:1px solid var(--c-border2);border-radius:100px;box-shadow:0 4px 24px rgba(0,0,0,.07)}
.nav-logo{display:flex;align-items:center;gap:10px;text-decoration:none}
.nav-logo-img{height:30px;width:auto;display:block;flex-shrink:0;object-fit:contain}
.nav-logo-text{font-family:var(--ff-h);font-size:16px;font-weight:700;color:var(--c-ink);letter-spacing:-0.03em;white-space:nowrap}
.nav-links{display:flex;align-items:center;gap:40px;list-style:none}
.nav-links a{font-size:14px;font-weight:400;color:var(--c-muted);transition:color .18s}
.nav-links a:hover{color:var(--c-ink)}
.btn-nav{font-family:var(--ff-h);font-size:13.5px;font-weight:600;background:var(--c-ink);color:#fff;padding:9px 20px;border-radius:var(--r-full);border:none;cursor:pointer;letter-spacing:-0.02em;transition:background .2s,transform .15s var(--ease-spring),box-shadow .2s;white-space:nowrap}
.btn-nav:hover{background:#2a2a26;transform:translateY(-1px);box-shadow:0 6px 18px rgba(0,0,0,.18)}

/* ── HERO ── */
.hero{min-height:100svh;display:flex;align-items:center;justify-content:center;padding-top:88px;position:relative;overflow:hidden;background:var(--c-bg)}
.hero-grain{position:absolute;inset:0;pointer-events:none;opacity:.35;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E")}
.hero-circle1{position:absolute;width:700px;height:700px;border-radius:50%;background:radial-gradient(circle,rgba(0,169,110,.07) 0%,transparent 64%);top:-140px;left:50%;transform:translateX(-50%);pointer-events:none}
.hero-circle2{position:absolute;width:440px;height:440px;border-radius:50%;background:radial-gradient(circle,rgba(212,160,0,.05) 0%,transparent 64%);bottom:-80px;right:-80px;pointer-events:none}
.grid-lines{position:absolute;inset:0;pointer-events:none;background-image:linear-gradient(rgba(0,0,0,.025) 1px,transparent 1px),linear-gradient(90deg,rgba(0,0,0,.025) 1px,transparent 1px);background-size:72px 72px;mask-image:radial-gradient(ellipse 80% 55% at 50% 0%,black 0%,transparent 100%)}

/* Hero layout: text left, visuals right */
.hero-layout{position:relative;z-index:2;width:100%;max-width:1200px;margin:0 auto;padding:40px 48px 80px;display:grid;grid-template-columns:1fr 420px;gap:64px;align-items:center}

.hero-text{display:flex;flex-direction:column;align-items:flex-start;gap:24px;text-align:left}

.hero-badge{display:inline-flex;align-items:center;gap:8px;padding:5px 14px 5px 8px;background:var(--c-vert-bg);border:1px solid var(--c-vert-br);border-radius:var(--r-full);font-size:12.5px;font-weight:500;color:var(--c-vert);animation:fadeUp .7s var(--ease-out) both}
.badge-dot{width:6px;height:6px;background:var(--c-vert);border-radius:50%;flex-shrink:0;animation:livePulse 2.4s ease-in-out infinite}
@keyframes livePulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.4;transform:scale(.65)}}
@keyframes fadeUp{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}

.hero-h1{font-size:clamp(44px,5.5vw,80px);font-weight:800;letter-spacing:-0.055em;line-height:1.05;color:var(--c-ink);animation:fadeUp .7s .08s var(--ease-out) both}
.hero-h1 .line2{display:block;white-space:nowrap;line-height:1.05}
.ac-vert{color:var(--c-vert)}
.ac-black{color:var(--c-ink)}

.hero-sub{font-size:clamp(15px,1.8vw,17px);font-weight:300;color:var(--c-mid);max-width:460px;line-height:1.78;animation:fadeUp .7s .16s var(--ease-out) both}

.hero-actions{display:flex;gap:12px;flex-wrap:wrap;animation:fadeUp .7s .22s var(--ease-out) both}
.btn-primary{font-family:var(--ff-h);font-size:15px;font-weight:600;background:var(--c-ink);color:#fff;padding:14px 28px;border-radius:var(--r-full);border:none;cursor:pointer;letter-spacing:-0.02em;display:inline-flex;align-items:center;gap:8px;transition:background .2s,transform .18s var(--ease-spring),box-shadow .2s}
.btn-primary:hover{background:#2a2a26;transform:translateY(-2px);box-shadow:0 10px 28px rgba(0,0,0,.2)}
.btn-primary svg{width:15px;height:15px;transition:transform .2s}
.btn-primary:hover svg{transform:translateX(3px)}
.btn-ghost{font-family:var(--ff-h);font-size:15px;font-weight:500;background:transparent;color:var(--c-text);padding:14px 28px;border-radius:var(--r-full);border:1px solid var(--c-border2);cursor:pointer;letter-spacing:-0.02em;transition:all .2s}
.btn-ghost:hover{border-color:rgba(0,0,0,.28);background:rgba(0,0,0,.04)}

.proof-strip{display:flex;align-items:center;gap:20px;flex-wrap:wrap;animation:fadeUp .7s .3s var(--ease-out) both}
.proof-item{display:flex;align-items:center;gap:6px;font-size:13px;color:var(--c-muted)}
.proof-hi{color:var(--c-vert);font-weight:600}
.proof-sep{color:rgba(0,0,0,.15);font-size:18px}

/* ── HERO VISUALS (right column) ── */
.hero-visuals{position:relative;animation:fadeUp .7s .12s var(--ease-out) both;padding:28px 20px 20px 0}

/* Main card */
.hv-card-main{background:#000000;border:1px solid rgba(255,255,255,.1);border-radius:20px;padding:24px;box-shadow:0 8px 40px rgba(0,0,0,.18);position:relative;overflow:hidden}
.hv-card-main::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,#00A96E,#00C97F);z-index:1}

/* Car image */
.hv-car{width:62%;height:auto;display:block;margin:0 auto 16px;object-fit:contain}

/* Charge indicator bar */
.hv-charge-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px}
.hv-charge-label{font-size:12px;font-weight:500;color:rgba(255,255,255,.6)}
.hv-charge-pct{font-family:var(--ff-h);font-size:22px;font-weight:800;color:var(--c-vert);letter-spacing:-0.04em}
.hv-bar-bg{height:8px;background:rgba(255,255,255,.1);border-radius:4px;overflow:hidden;margin-bottom:16px}
.hv-bar-fill{height:8px;background:linear-gradient(90deg,#00A96E,#00D4A0);border-radius:4px;width:0;animation:fillBar 2s 1s var(--ease-out) forwards}
@keyframes fillBar{from{width:0}to{width:73%}}

.hv-meta{display:flex;gap:8px}
.hv-meta-pill{flex:1;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:10px;padding:10px 12px}
.hv-meta-pill-label{font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:.08em;color:rgba(255,255,255,.45);margin-bottom:3px}
.hv-meta-pill-val{font-family:var(--ff-h);font-size:14px;font-weight:700;color:#fff;letter-spacing:-0.03em}

/* Floating mini-cards */
.hv-float1{position:absolute;top:-14px;right:-14px;z-index:20;background:#1A1A1A;border:1px solid rgba(255,255,255,.12);border-radius:14px;padding:12px 16px;box-shadow:0 4px 20px rgba(0,0,0,.12);display:flex;align-items:center;gap:10px;white-space:nowrap;animation:floatCard1 4s ease-in-out infinite 1.5s}
.hv-float2{position:absolute;bottom:-14px;left:-14px;z-index:20;background:#1A1A1A;border:1px solid rgba(255,255,255,.12);border-radius:14px;padding:12px 16px;box-shadow:0 4px 20px rgba(0,0,0,.12);display:flex;align-items:center;gap:10px;white-space:nowrap;animation:floatCard2 4.5s ease-in-out infinite 2s}
@keyframes floatCard1{0%,100%{transform:translateY(0)}50%{transform:translateY(-5px)}}
@keyframes floatCard2{0%,100%{transform:translateY(0)}50%{transform:translateY(4px)}}
.hv-float-icon{width:32px;height:32px;border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.hv-float-icon.green{background:var(--c-vert-bg)}
.hv-float-icon.yellow{background:var(--c-jaune-bg)}
.hv-float-icon svg{width:16px;height:16px}
.hv-float-text-top{font-size:11px;color:rgba(255,255,255,.5);font-weight:400;line-height:1.2}
.hv-float-text-bot{font-family:var(--ff-h);font-size:13px;font-weight:700;color:#fff;letter-spacing:-0.02em;line-height:1.2}

/* ── AVIS CLIENT ── */
.review-wrap{border-top:1px solid var(--c-border);background:var(--c-bg3);padding:64px 48px}
.review-header{max-width:1080px;margin:0 auto 40px;text-align:center}
.reviews-grid{max-width:1080px;margin:0 auto;display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
.review-card{background:var(--c-bg2);border:1px solid var(--c-border);border-radius:var(--r-xl);padding:28px;box-shadow:var(--shadow-card)}
.review-stars{display:flex;gap:3px;margin-bottom:16px}
.review-stars svg{width:15px;height:15px;fill:var(--c-jaune-lt);color:var(--c-jaune-lt)}
.review-quote{font-size:14px;font-weight:400;line-height:1.7;color:var(--c-mid);margin-bottom:20px}
.review-author{display:flex;align-items:center;gap:10px}
.review-avatar{width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:var(--ff-h);font-size:12px;font-weight:700;flex-shrink:0}
.review-author-info{text-align:left}
.review-name{font-family:var(--ff-h);font-size:13px;font-weight:700;color:var(--c-ink);letter-spacing:-0.02em}
.review-role{font-size:11px;color:var(--c-muted);font-weight:300;line-height:1.4}

/* ── STATS ── */
.stats-band{border-top:1px solid var(--c-border);border-bottom:1px solid var(--c-border);background:var(--c-bg2)}
.stats-inner{max-width:960px;margin:0 auto;display:grid;grid-template-columns:repeat(3,1fr)}
.stat-item{text-align:center;padding:48px 32px;border-right:1px solid var(--c-border)}
.stat-item:last-child{border-right:none}
.stat-num{font-family:var(--ff-h);font-size:52px;font-weight:800;letter-spacing:-0.055em;line-height:1;color:var(--c-vert);display:block;margin-bottom:6px}
.stat-num.jaune{color:var(--c-jaune)}
.stat-label{font-size:13px;font-weight:300;color:var(--c-muted);line-height:1.55;max-width:170px;margin:0 auto}

/* ── SECTION WRAPPER ── */
.sw{max-width:1080px;margin:0 auto;padding:80px 48px 64px}
.section-tag{display:inline-flex;align-items:center;gap:8px;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.12em;color:var(--c-vert);margin-bottom:20px}
.section-tag::before{content:'';display:inline-block;width:14px;height:1px;background:var(--c-vert)}
.section-h2{font-size:clamp(32px,4.5vw,56px);font-weight:800;margin-bottom:16px;max-width:680px}
.section-lead{font-size:17px;font-weight:300;color:var(--c-mid);line-height:1.8;max-width:520px}

/* ── WHY CARDS ── */
.why-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:64px}
.why-card{background:var(--c-bg2);border:1px solid var(--c-border);border-radius:var(--r-xl);padding:32px 28px;position:relative;overflow:hidden;box-shadow:var(--shadow-card);transition:transform .28s var(--ease-out),box-shadow .28s}
.why-card:hover{transform:translateY(-5px);box-shadow:var(--shadow-hover)}
.why-num{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--c-muted);margin-bottom:32px}
.why-icon{width:48px;height:48px;border-radius:var(--r-md);display:flex;align-items:center;justify-content:center;margin-bottom:20px}
.ic-v{background:rgba(0,169,110,.1)} .ic-j{background:rgba(212,160,0,.1)} .ic-c{background:rgba(0,0,0,.05)}
.why-icon svg{width:24px;height:24px}
.why-card h4{font-family:var(--ff-h);font-size:18px;font-weight:700;letter-spacing:-0.035em;margin-bottom:12px}
.why-card p{font-size:14px;color:var(--c-muted);line-height:1.75;font-weight:300}

/* ── PROCESS ── */
.process-wrap{border-top:1px solid var(--c-border);background:var(--c-bg)}
.process-grid{display:grid;grid-template-columns:repeat(4,1fr);border:1px solid var(--c-border);border-radius:var(--r-xl);overflow:hidden;margin-top:64px;background:var(--c-bg2);box-shadow:var(--shadow-card)}
.p-step{padding:32px 24px;border-right:1px solid var(--c-border);transition:background .2s}
.p-step:last-child{border-right:none}
.p-step:hover{background:rgba(0,0,0,.02)}
.p-num{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;margin-bottom:32px}
.p-num.nv{color:var(--c-vert)} .p-num.nj{color:var(--c-jaune)} .p-num.nm{color:var(--c-muted)}
.p-icon{width:40px;height:40px;border-radius:var(--r-sm);display:flex;align-items:center;justify-content:center;margin-bottom:20px}
.p-icon svg{width:20px;height:20px}
.pi-v{background:rgba(0,169,110,.1)} .pi-j{background:rgba(212,160,0,.1)} .pi-m{background:rgba(0,0,0,.05)}
.p-step h4{font-family:var(--ff-h);font-size:15px;font-weight:700;letter-spacing:-0.03em;margin-bottom:8px}
.p-step p{font-size:13px;color:var(--c-muted);line-height:1.6;font-weight:300}

/* ── SIMULATEUR ── */
.sim-section{border-top:1px solid var(--c-border)}
.sim-card{background:var(--c-bg2);border:1px solid var(--c-border);border-radius:var(--r-xl);overflow:hidden;margin-top:64px;box-shadow:var(--shadow-card)}
.sim-bar-top{display:flex;align-items:center;justify-content:space-between;padding:20px 32px;border-bottom:1px solid var(--c-border);background:var(--c-bg3)}
.sim-bar-left{display:flex;align-items:center;gap:16px}
.sim-icon-box{width:34px;height:34px;background:var(--c-vert-bg);border:1px solid var(--c-vert-br);border-radius:var(--r-sm);display:flex;align-items:center;justify-content:center}
.sim-icon-box svg{width:16px;height:16px}
.sim-bar-top h3{font-size:14px;font-weight:700;letter-spacing:-0.03em;color:var(--c-ink)}
.sim-bar-top p{font-size:12px;color:var(--c-muted)}
.sim-badge{font-size:11px;font-weight:600;background:var(--c-vert-bg);border:1px solid var(--c-vert-br);color:var(--c-vert);padding:4px 12px;border-radius:var(--r-full);letter-spacing:.06em}
.sim-prog{display:flex;gap:6px;padding:28px 32px 0}
.sim-pb{flex:1;height:2px;border-radius:2px;background:rgba(0,0,0,.08);transition:background .4s var(--ease-out)}
.sim-pb.active{background:var(--c-vert)} .sim-pb.done{background:rgba(0,169,110,.4)}
.sim-body{padding:32px}
.sim-q{display:none}
.sim-q.active{display:block;animation:fadeUp .4s var(--ease-out) both}
.q-step{font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.1em;color:var(--c-muted);margin-bottom:8px}
.q-label{font-family:var(--ff-h);font-size:clamp(20px,3vw,26px);font-weight:700;letter-spacing:-0.04em;margin-bottom:8px;color:var(--c-ink)}
.q-sub{font-size:14px;color:var(--c-muted);font-weight:300;margin-bottom:28px}
.sim-opts{display:grid;grid-template-columns:repeat(auto-fit,minmax(185px,1fr));gap:12px}
.sim-opt{background:var(--c-bg);border:1px solid var(--c-border);border-radius:var(--r-lg);padding:20px;cursor:pointer;text-align:left;user-select:none;transition:border-color .2s,background .2s,transform .2s var(--ease-spring)}
.sim-opt:hover{border-color:rgba(0,169,110,.4);background:rgba(0,169,110,.04);transform:translateY(-2px)}
.sim-opt.sel{border-color:var(--c-vert);background:rgba(0,169,110,.06)}
.opt-emoji{font-size:24px;display:block;margin-bottom:12px;line-height:1}
.opt-title{font-family:var(--ff-h);font-size:15px;font-weight:700;letter-spacing:-0.03em;margin-bottom:3px;color:var(--c-ink)}
.opt-desc{font-size:12px;color:var(--c-muted);font-weight:300}

/* RESULT */
.sim-result{display:none}
.sim-result.active{display:block;animation:fadeUp .5s var(--ease-out) both}
.res-head{padding-bottom:28px;border-bottom:1px solid var(--c-border);margin-bottom:28px}
.res-badge{display:inline-flex;align-items:center;gap:6px;font-size:11px;font-weight:600;color:var(--c-vert);background:var(--c-vert-bg);border:1px solid var(--c-vert-br);padding:4px 12px;border-radius:var(--r-full);margin-bottom:12px;text-transform:uppercase;letter-spacing:.08em}
.res-title{font-family:var(--ff-h);font-size:clamp(20px,3vw,28px);font-weight:800;letter-spacing:-0.04em;margin-bottom:8px;color:var(--c-ink)}
.res-sub{font-size:14px;color:var(--c-muted);font-weight:300}
.metrics{display:grid;grid-template-columns:repeat(auto-fit,minmax(155px,1fr));gap:12px;margin-bottom:32px}
.metric{background:var(--c-bg);border:1px solid var(--c-border);border-radius:var(--r-md);padding:20px;transition:border-color .2s}
.metric:hover{border-color:var(--c-border2)}
.m-label{font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:.1em;color:var(--c-muted);margin-bottom:6px}
.m-val{font-family:var(--ff-h);font-size:21px;font-weight:800;letter-spacing:-0.04em;line-height:1;color:var(--c-ink)}
.m-val.v{color:var(--c-vert)} .m-val.j{color:var(--c-jaune)}
.lead-block{background:linear-gradient(135deg,rgba(0,169,110,.05) 0%,rgba(212,160,0,.04) 100%);border:1px solid rgba(0,169,110,.15);border-radius:var(--r-lg);padding:28px}
.lead-block h4{font-family:var(--ff-h);font-size:17px;font-weight:700;letter-spacing:-0.03em;margin-bottom:5px;color:var(--c-ink)}
.lead-block>p{font-size:14px;color:var(--c-muted);font-weight:300;margin-bottom:20px}
.form-row{display:grid;grid-template-columns:1fr 1fr 1fr auto;gap:12px}
.form-in{background:var(--c-bg2);border:1px solid var(--c-border2);border-radius:var(--r-sm);padding:12px 15px;font-size:14px;font-family:var(--ff-b);color:var(--c-text);outline:none;transition:border-color .2s,box-shadow .2s}
.form-in::placeholder{color:rgba(0,0,0,.28)}
.form-in:focus{border-color:rgba(0,169,110,.5);box-shadow:0 0 0 3px rgba(0,169,110,.1)}
.btn-sub{font-family:var(--ff-h);font-size:14px;font-weight:700;background:var(--c-ink);color:#fff;border:none;border-radius:var(--r-sm);padding:12px 22px;cursor:pointer;white-space:nowrap;letter-spacing:-0.02em;transition:background .2s,transform .18s var(--ease-spring)}
.btn-sub:hover{background:#2a2a26;transform:translateY(-1px)}
.form-legal{font-size:11px;color:var(--c-muted);margin-top:12px}
